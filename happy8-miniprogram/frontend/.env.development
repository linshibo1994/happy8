# WeChat Mini Program Environment Configuration

# Node Environment
NODE_ENV=development
UNI_PLATFORM=mp-weixin

# UNI-APP Required Directories
UNI_INPUT_DIR=./src
UNI_OUTPUT_DIR=./dist

# API Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=10000
VITE_API_VERSION=v1

# WeChat Configuration  
VITE_WECHAT_APPID=wx50e6ca6db77c98b8

# Environment
VITE_APP_ENV=development
VITE_DEBUG=true

# Features
VITE_ENABLE_MOCK=false
VITE_ENABLE_VCONSOLE=false
