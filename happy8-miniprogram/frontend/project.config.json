{
  "description": "Happy8快乐8智能预测微信小程序",
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "node_modules"
      },
      {
        "type": "folder", 
        "value": ".git"
      },
      {
        "type": "folder",
        "value": ".npm-cache"
      },
      {
        "type": "file",
        "value": "*.md"
      },
      {
        "type": "file",
        "value": "package*.json"
      },
      {
        "type": "file",
        "value": "vite.config.*"
      },
      {
        "type": "file",
        "value": "tsconfig.*"
      },
      {
        "type": "file",
        "value": ".env*"
      }
    ]
  },
  "setting": {
    "urlCheck": false,
