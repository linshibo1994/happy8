# 开发环境配置
DATABASE_URL=mysql://happy8_user:happy8_pass_2025@localhost:3306/happy8_miniprogram
REDIS_URL=redis://:happy8_redis_2025@localhost:6379/0

# JWT密钥
SECRET_KEY=happy8_jwt_secret_key_2025_very_long_and_secure
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 环境标识
ENVIRONMENT=development
DEBUG=true

# 微信小程序配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 微信支付配置
WECHAT_PAY_MCHID=your_merchant_id
WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/private_key.pem
WECHAT_PAY_CERT_SERIAL=your_cert_serial
WECHAT_PAY_APIV3_KEY=your_apiv3_key
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/callback

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis连接池配置
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 邮件配置（用于通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=your_email@gmail.com

# 文件上传配置
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10485760  # 10MB

# 预测算法配置
PREDICTION_CACHE_TTL=3600  # 1小时
PREDICTION_TIMEOUT=30  # 30秒
MAX_PREDICTIONS_PER_DAY_FREE=5
MAX_PREDICTIONS_PER_DAY_VIP=50